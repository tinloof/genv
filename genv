#!/usr/bin/env bash
# genv — a focused GitHub CLI wrapper for a repo's Actions env vars & secrets.
# Wraps `gh`; see `genv --help`. No external deps beyond gh (+ its bundled jq).
set -euo pipefail

VERSION=1.0.0

err() { printf 'genv: %s\n' "$*" >&2; }

require_gh() {
  command -v gh >/dev/null 2>&1 || {
    err "requires the GitHub CLI (gh) — install from https://cli.github.com"
    exit 127
  }
  gh auth status >/dev/null 2>&1 || {
    err "not authenticated with GitHub — run: gh auth login"
    exit 1
  }
}

# Create the environment if it doesn't already exist — writes (push/secret) need
# it to exist, and GitHub won't auto-create it. PUT is idempotent.
ensure_env() {
  if gh api "repos/{owner}/{repo}/environments/$1" >/dev/null 2>&1; then
    return 0
  fi
  printf 'genv: environment "%s" does not exist — creating it\n' "$1" >&2
  if ! gh api --method PUT "repos/{owner}/{repo}/environments/$1" >/dev/null 2>&1; then
    err "failed to create environment \"$1\" (do you have admin access to the repo?)"
    return 1
  fi
}

usage() {
  cat <<'EOF'
genv — GitHub Actions env vars & secrets, without the noise

USAGE
  genv <command> [options]

COMMANDS
  pull     Write GitHub variables to a dotenv file (default: .env)
  push     Set GitHub variables from a dotenv file (default: .env)
  var      Set a single GitHub variable
  secret   Set a secret, optionally with a fallback variable
  list     List variables and secrets in one table
  help     Show this help (also: genv <command> --help)

OPTIONS
  -e, --env <name>    Target an environment (default: repository-level)
  -f, --file <path>   Dotenv file for pull/push (default: .env)
  -h, --help          Show help

EXAMPLES
  genv pull -e production
  genv push -e staging -f .env.stg
  genv var LOG_LEVEL debug -e production
  genv secret API_KEY --fallback sk-dummy -e production   # value read from stdin
  genv secret DEBUG verbose --fallback off                # repo-level, inline value
  genv list -e production

Wraps the GitHub CLI (gh). Run `gh auth login` if you're not signed in.
EOF
}

usage_pull() {
  cat <<'EOF'
genv pull — write GitHub Actions variables into a dotenv file

USAGE
  genv pull [-e <env>] [-f <file>]

  -e, --env <name>    Environment to read from (default: repository-level)
  -f, --file <path>   Output dotenv file (default: .env)

Secrets are never included — GitHub never allows their values to be read back.
EOF
}

usage_push() {
  cat <<'EOF'
genv push — set GitHub Actions variables from a dotenv file

USAGE
  genv push [-e <env>] [-f <file>]

  -e, --env <name>    Environment to write to (default: repository-level)
  -f, --file <path>   Input dotenv file (default: .env)

The environment is created automatically if it doesn't exist.
Only adds/updates the keys in the file; never deletes variables you removed.
EOF
}

usage_secret() {
  cat <<'EOF'
genv secret — set a GitHub Actions secret (write-only), with optional fallback

USAGE
  genv secret <NAME> [value] [--fallback <value>] [-e <env>]

  <NAME>              Secret name (also names the fallback variable)
  [value]            Secret value; if omitted, read from stdin (keeps it out
                     of your shell history)
  --fallback <value> Also set a same-named variable, so a workflow can use:
                       ${{ secrets.NAME || vars.NAME }}
  -e, --env <name>   Environment (default: repository-level; created if missing)

EXAMPLES
  genv secret API_KEY sk-real --fallback sk-dummy -e production
  printf '%s' "$TOKEN" | genv secret API_KEY -e production
EOF
}

usage_var() {
  cat <<'EOF'
genv var — set a single GitHub Actions variable

USAGE
  genv var <NAME> [value] [-e <env>]

  <NAME>             Variable name
  [value]            Value; if omitted, read from stdin
  -e, --env <name>   Environment (default: repository-level; created if missing)

EXAMPLES
  genv var LOG_LEVEL debug
  genv var API_URL https://api.example.com -e production
EOF
}

usage_list() {
  cat <<'EOF'
genv list — list variables and secrets in one table

USAGE
  genv list [-e <env>]

  -e, --env <name>   Environment to list (default: repository-level)

TYPE is "secret" or "var". A secret's value is hidden (write-only); if it has a
same-named fallback variable, that value shows in FALLBACK (otherwise "-").
EOF
}

cmd_pull() {
  local e='' f='.env'
  while [ $# -gt 0 ]; do
    case "$1" in
      -e|--env)  [ $# -ge 2 ] || { err "pull: --env requires a value"; return 2; }; e="$2"; shift 2 ;;
      -f|--file) [ $# -ge 2 ] || { err "pull: --file requires a value"; return 2; }; f="$2"; shift 2 ;;
      -h|--help) usage_pull; return 0 ;;
      *)         err "pull: unexpected argument '$1'"; return 2 ;;
    esac
  done
  require_gh
  gh variable list ${e:+--env "$e"} --json name,value --jq '.[] | "\(.name)=\(.value)"' > "$f"
  local count; count=$(grep -c . "$f" 2>/dev/null) || count=0
  printf '✓ wrote %s var(s) to %s\n' "$count" "$f"
}

cmd_push() {
  local e='' f='.env'
  while [ $# -gt 0 ]; do
    case "$1" in
      -e|--env)  [ $# -ge 2 ] || { err "push: --env requires a value"; return 2; }; e="$2"; shift 2 ;;
      -f|--file) [ $# -ge 2 ] || { err "push: --file requires a value"; return 2; }; f="$2"; shift 2 ;;
      -h|--help) usage_push; return 0 ;;
      *)         err "push: unexpected argument '$1'"; return 2 ;;
    esac
  done
  [ -f "$f" ] || { err "push: file not found: $f"; return 1; }
  require_gh
  if [ -n "$e" ]; then ensure_env "$e"; fi
  gh variable set --env-file "$f" ${e:+--env "$e"}
  printf '✓ pushed %s to %s\n' "$f" "${e:-repo}"
}

cmd_secret() {
  if [ "${1:-}" = set ]; then shift; fi   # tolerate `genv secret set NAME`
  local n='' v='' fb='' e='' vset=''
  while [ $# -gt 0 ]; do
    case "$1" in
      -e|--env)   [ $# -ge 2 ] || { err "secret: --env requires a value"; return 2; }; e="$2"; shift 2 ;;
      --fallback) [ $# -ge 2 ] || { err "secret: --fallback requires a value"; return 2; }; fb="$2"; shift 2 ;;
      -h|--help)  usage_secret; return 0 ;;
      -*)         err "secret: unknown option '$1'"; return 2 ;;
      *)          if [ -z "$n" ]; then n="$1"; else v="$1"; vset=1; fi; shift ;;
    esac
  done
  [ -n "$n" ] || { err "secret: missing secret NAME"; echo >&2; usage_secret >&2; return 2; }
  require_gh
  if [ -n "$e" ]; then ensure_env "$e"; fi
  if [ -n "$vset" ]; then
    gh secret set "$n" -b "$v" ${e:+--env "$e"}
  else
    gh secret set "$n" ${e:+--env "$e"}
  fi
  [ -z "$fb" ] || gh variable set "$n" -b "$fb" ${e:+--env "$e"}
  printf '✓ set secret %s%s%s\n' "$n" "${e:+ (env $e)}" "${fb:+ + fallback var}"
}

cmd_var() {
  if [ "${1:-}" = set ]; then shift; fi   # tolerate `genv var set NAME`
  local n='' v='' e='' vset=''
  while [ $# -gt 0 ]; do
    case "$1" in
      -e|--env)  [ $# -ge 2 ] || { err "var: --env requires a value"; return 2; }; e="$2"; shift 2 ;;
      -h|--help) usage_var; return 0 ;;
      -*)        err "var: unknown option '$1'"; return 2 ;;
      *)         if [ -z "$n" ]; then n="$1"; else v="$1"; vset=1; fi; shift ;;
    esac
  done
  [ -n "$n" ] || { err "var: missing variable NAME"; echo >&2; usage_var >&2; return 2; }
  require_gh
  if [ -n "$e" ]; then ensure_env "$e"; fi
  if [ -n "$vset" ]; then
    gh variable set "$n" -b "$v" ${e:+--env "$e"}
  else
    gh variable set "$n" ${e:+--env "$e"}
  fi
  printf '✓ set variable %s%s\n' "$n" "${e:+ (env $e)}"
}

cmd_list() {
  local e=''
  while [ $# -gt 0 ]; do
    case "$1" in
      -e|--env)  [ $# -ge 2 ] || { err "list: --env requires a value"; return 2; }; e="$2"; shift 2 ;;
      -h|--help) usage_list; return 0 ;;
      *)         err "list: unexpected argument '$1'"; return 2 ;;
    esac
  done
  require_gh

  # If an environment was given, verify it exists so we can show a clear message
  # instead of gh's raw 404.
  if [ -n "$e" ] && ! gh api "repos/{owner}/{repo}/environments/$e" >/dev/null 2>&1; then
    local repo; repo="$(gh repo view --json nameWithOwner --jq .nameWithOwner 2>/dev/null || echo "this repository")"
    err "environment \"$e\" not found in $repo"
    err "run 'genv list' for repository-level config, or check the environment name"
    return 1
  fi

  local vars secs rows
  if ! vars="$(gh variable list ${e:+--env "$e"} --json name,value --jq '.[] | "\(.name)\t\(.value)"' 2>/dev/null)"; then
    err "could not read variables (check your gh auth and repo access)"
    return 1
  fi
  if ! secs="$(gh secret list ${e:+--env "$e"} --json name --jq '.[].name' 2>/dev/null)"; then
    err "could not read secrets (check your gh auth and repo access)"
    return 1
  fi

  if [ -n "$e" ]; then echo "Environment: $e"; else echo "Repository-level"; fi

  # Tag each line (S=secret name, V=variable name+value), then merge by name:
  # a secret folds in its same-named variable as the fallback.
  rows="$(
    { printf '%s\n' "$secs" | awk 'NF{print "S\t"$0}'
      printf '%s\n' "$vars" | awk 'NF{print "V\t"$0}'
    } | awk -F'\t' '
      $1=="V"{ val[$2]=$3; isvar[$2]=1; name[$2]=1 }
      $1=="S"{ issec[$2]=1; name[$2]=1 }
      END{
        for (k in name) {
          if (issec[k]) { fb=(isvar[k] ? val[k] : "-"); print k"\tsecret\t(hidden)\t"fb }
          else          { print k"\tvar\t"val[k]"\t-" }
        }
      }' | LC_ALL=C sort -f
  )"

  if [ -z "$rows" ]; then
    echo "(no variables or secrets)"
    return 0
  fi

  # Render an aligned table (pad each column to its max width).
  { printf 'NAME\tTYPE\tVALUE\tFALLBACK\n'; printf '%s\n' "$rows"; } | awk -F'\t' '
    { for (i=1;i<=NF;i++) { cell[NR,i]=$i; if (length($i)>w[i]) w[i]=length($i) }
      if (NF>nf) nf=NF; n=NR }
    END {
      for (r=1;r<=n;r++) {
        out=""
        for (i=1;i<=nf;i++) {
          s=cell[r,i]; pad=w[i]-length(s)
          while (pad-- > 0) s=s" "
          out=out s (i<nf ? "  " : "")
        }
        sub(/[ ]+$/,"",out); print out
      }
    }'
}

if [ $# -eq 0 ]; then usage; exit 0; fi
cmd="$1"; shift
case "$cmd" in
  pull)                 cmd_pull "$@" ;;
  push)                 cmd_push "$@" ;;
  var|variable)         cmd_var "$@" ;;
  secret)               cmd_secret "$@" ;;
  list|ls)              cmd_list "$@" ;;
  help|-h|--help)       usage ;;
  version|--version)    printf 'genv %s\n' "$VERSION" ;;
  *)                    err "unknown command '$cmd' (try: genv --help)"; exit 2 ;;
esac
